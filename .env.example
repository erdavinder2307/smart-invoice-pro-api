COSMOS_URI=
COSMOS_KEY=
COSMOS_DB_NAME=
COSMOS_CONTAINER_NAME=

# Bank Import raw-file retention (reuse existing Azure Storage account)
# Use the connection string for your existing storage account (for example: solidevfunctionstorage)
BANK_IMPORT_BLOB_CONNECTION_STRING=
BANK_IMPORT_BLOB_CONTAINER=bank-imports
# Optional: force sync/async processing (`true` for queue worker, `false` for inline)
BANK_IMPORT_ASYNC=true

# Claude AI (Anthropic) — AI-powered transaction reconciliation
# Get your key from https://console.anthropic.com/
ANTHROPIC_API_KEY=
# Optional: override the Claude model used for matching
# CLAUDE_MODEL=claude-3-5-haiku-20241022

# Zoho Payments
ZOHO_PAYMENTS_CLIENT_ID=
ZOHO_PAYMENTS_CLIENT_SECRET=
ZOHO_PAYMENTS_REFRESH_TOKEN=
ZOHO_PAYMENTS_ACCOUNT_ID=
ZOHO_PAYMENTS_WEBHOOK_SECRET=

# Azure Email (Azure Communication Services sender address)
AZURE_SENDER_EMAIL=

# Frontend URL (for redirect after payment)
FRONTEND_URL=http://localhost:3000

# CORS allowlist (comma-separated origins)
# Example:
# CORS_ALLOWED_ORIGINS=https://polite-rock-016dcf900.1.azurestaticapps.net,https://app.example.com
CORS_ALLOWED_ORIGINS=
